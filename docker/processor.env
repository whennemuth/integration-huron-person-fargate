# AWS and environment parameters.
AWS_PROFILE=infnprd
REGION=us-east-2
NODE_ENV=production

# Name of the S3 bucket containing the original large input JSON file with person records.
INPUT_BUCKET=huron-person-file-drop-dev

# HURON_PERSON_CONFIG_JSON='{"dataSource":{"person":{"endpointConfig":{"baseUrl":"https://prod-butest-fm.snaplogic.io","apiKey":"your-api-key-here","timeout":300000},"fetchPath":"/api/1/rest/feed-master/queue/BUTest/Admin-Integration-Services/CommonServiceWrappers/huronIRBPerson","fieldsOfInterest":["personid","personBasic.names[*].firstName","personBasic.names[*].lastName","personBasic.names[*].middleName"]},"people":{"bucketName":"huron-person-file-drop-dev","key":"20260303111609986/chunk-0011.ndjson","region":"us-east-2"},"_people":{"endpointConfig":{"baseUrl":"https://prod-butest-fm.snaplogic.io","apiKey":"your-api-key-here","timeout":7200000},"fetchPath":"/api/1/rest/feed/run/task/BUTest/Admin-Integration-Services/GenericGets/huronIRBgetPersonByPopulation","fieldsOfInterest":["personid","personBasic.names[*].firstName","personBasic.names[*].lastName","personBasic.names[*].middleName"]},"terms":{"endpointConfig":{"baseUrl":"https://prod-buprod-fm.snaplogic.io","apiKey":"your-api-key-here","timeout":300000},"fetchPath":"/api/1/rest/feed/run/task/BUProd/Admin-Integration-Services/GenericGets/getCurrentTermFromCS"}},"dataTarget":{"endpointConfig":{"baseUrl":"https://bu.hrs-staging.com","authMethod":"externalToken","externalToken":"your-external-token-here","userId":"bu-sso_wrh@bu.edu","loginSvcPath":"/loginsvc/api/v1/token/","timeout":30000},"personsPath":"/api/v2/persons","organizationsPath":"/api/v2/organizations"},"integration":{"clientId":"huron-person-integration","batchSize":100,"timeout":30000},"storage":{"type":"s3","config":{"bucketName":"huron-person-file-drop-dev","keyPrefix":"delta-storage/","region":"us-east-2"}}}'

# S3 details for the chunk files output by the chunker service.
CHUNKS_BUCKET=huron-person-chunks-dev
CHUNK_KEY=chunks/person-full/2026-04-09T15:28:18.703Z/chunk-0000.ndjson
# or...
# SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/770203350335/huron-person-chunks-dev

# Other required configurations for the processor service.
HURON_API_ENDPOINT=https://bu.hrs-staging.com

SECRET_ARN=arn:aws:secretsmanager:us-east-2:770203350335:secret:huron-person-fargate-processor/integration/_config/dev-LaYGXj

BULK_RESET=true

# Dryrun mode (set to true to avoid actual creates/puts/patches to the target API)
DRY_RUN=true
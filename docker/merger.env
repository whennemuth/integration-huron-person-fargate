# AWS and environment parameters.
AWS_PROFILE=infnprd
REGION=us-east-2
NODE_ENV=production

# Name of the S3 bucket containing the original large input JSON file with person records.
INPUT_BUCKET=huron-person-file-drop-dev

# Name of the bucket for chunk files - ndjson files with primary key and person delta hashes - 
# output by the processor service.
CHUNKS_BUCKET=huron-person-chunks-dev

PRIMARY_KEY_FIELDS=sourceIdentifier
SHARED_DELTA_STORAGE_DIR=delta-storage

# Dryrun mode (set to true to avoid actual creates/puts/patches to the target API)
DRY_RUN=true
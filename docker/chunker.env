# AWS and environment parameters.
AWS_PROFILE=infnprd
REGION=us-east-2
NODE_ENV=production

# Source fetch type: 's3' or 'api'
# - 's3': Read from S3 bucket (uses INPUT_BUCKET and INPUT_KEY)
# - 'api': Fetch from API endpoint (uses config from HURON_PERSON_CONFIG_JSON/SECRET_ARN and SYNC_TYPE)
SOURCE_FETCH_TYPE=s3

# S3 mode: Details of the original large input json file with person records.
INPUT_BUCKET=huron-person-file-drop-dev
INPUT_KEY=person-full/2026-03-03T19:58:41.277Z-people.json

# API mode: Configuration and sync type
# Config loaded via same pattern as processor.ts:
# - HURON_PERSON_CONFIG_JSON (from TaskDef secrets in Fargate)
# - SECRET_ARN (fallback to Secrets Manager)
# - HURON_PERSON_CONFIG_PATH (local dev only, e.g., ../integration-huron-person/config.json)
# SYNC_TYPE=person-full

# Name of the S3 bucket for chunk files - ndjson files with subsets of person records -
# output by the chunker service.
CHUNKS_BUCKET=huron-person-chunks-dev

# Expiration for chunk files in days (optional, default: 7)
DATA_CHUNK_EXPIRATION_DAYS=14

# Other required configurations for the chunker service.
ITEMS_PER_CHUNK=200
PERSON_ID_FIELD=personid

# Dry run mode for testing - set to true to avoid actual writes to S3 and just log actions instead.
DRY_RUN=true